# ── App ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1
DEBUG=true

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kyc_user:kyc_pass@localhost:5432/kyc_db

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS Core ─────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>

# ── S3 ───────────────────────────────────────────────
S3_BUCKET_NAME=kyc-documents-prod
S3_PRESIGNED_URL_EXPIRY=900

# ── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Rekognition ──────────────────────────────────────
FACE_SIMILARITY_THRESHOLD=90.0
FACE_CONFIDENCE_THRESHOLD=99.0

# ── Groq AI ──────────────────────────────────────────
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama3-70b-8192

# ── AML / OpenSanctions ──────────────────────────────
OPENSANCTIONS_API_KEY=<your-opensanctions-key>
OPENSANCTIONS_API_URL=https://api.opensanctions.org

# ── Risk Engine Thresholds ───────────────────────────
RISK_AUTO_APPROVE_MAX=29
RISK_MANUAL_REVIEW_MAX=59
RISK_ESCALATION_MAX=84
