# ── Supabase Configuration Template ──────────────────────────────────────────
# This file shows how to configure Supabase credentials
# Copy this to .env and fill in your actual Supabase project details

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
API_V1_PREFIX=/api/v1
DEBUG=true

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Format: postgresql+asyncpg://postgres:[PASSWORD]@[HOST]:[PORT]/postgres
# Get this from Supabase Dashboard → Settings → Database → Connection info
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR_PASSWORD]@[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_URL_CELERY=

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=[YOUR_AWS_ACCESS_KEY]
AWS_SECRET_ACCESS_KEY=[YOUR_AWS_SECRET_KEY]

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=kyc-documents-prod
S3_PRESIGNED_URL_EXPIRY=900

# ── Supabase Auth & Database ─────────────────────────────────────────────────
# Get these from Supabase Dashboard → Settings → API

# Project URL - looks like: https://xxxxx.supabase.co
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co

# Anon Key - for client-side authentication
SUPABASE_ANON_KEY=[YOUR_ANON_KEY]

# Service Role Key - NEVER expose to client, only backend (do not commit!)
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# JWT Secret - for validating Supabase tokens
SUPABASE_JWT_SECRET=[YOUR_JWT_SECRET]

# ── Face Recognition (AWS Rekognition) ───────────────────────────────────────
FACE_SIMILARITY_THRESHOLD=90.0
FACE_CONFIDENCE_THRESHOLD=99.0

# ── AI Models (Groq) ─────────────────────────────────────────────────────────
GROQ_API_KEY=[YOUR_GROQ_API_KEY]
GROQ_MODEL=llama3-70b-8192

# ── AML / Risk Screening (OpenSanctions) ─────────────────────────────────────
OPENSANCTIONS_API_KEY=[YOUR_OPENSANCTIONS_KEY]
OPENSANCTIONS_API_URL=https://api.opensanctions.org

# ── Risk Engine Thresholds ───────────────────────────────────────────────────
RISK_AUTO_APPROVE_MAX=29
RISK_MANUAL_REVIEW_MAX=59
RISK_ESCALATION_MAX=84

# ────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS:
#
# 1. Go to https://app.supabase.com
# 2. Create new project (or use existing)
# 3. Navigate to Settings → API
# 4. Copy the following:
#    - Project URL → SUPABASE_URL
#    - Anon key → SUPABASE_ANON_KEY
#    - Service role key → SUPABASE_SERVICE_ROLE_KEY
# 5. Navigate to Settings → Database
#    - Get password: click "Reveal" next to postgres password
#    - Build DATABASE_URL:
#      postgresql+asyncpg://postgres:[PASSWORD]@[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
# 6. Navigate to Settings → JWT Settings
#    - Copy secret → SUPABASE_JWT_SECRET
#
# 7. Fill in AWS/S3 credentials
# 8. Fill in API keys for services (Groq, OpenSanctions)
# 9. Save as .env in project root
# 10. Run: python setup_supabase.py
# 11. Run: docker-compose up -d
# ────────────────────────────────────────────────────────────────────────────
